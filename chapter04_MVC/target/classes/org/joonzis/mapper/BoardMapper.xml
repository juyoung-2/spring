<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.joonzis.mapper.BoardMapper">

    <!-- 전체 리스트 조회 -->
    <select id="getList" resultType="org.joonzis.domain.BoardVO">
        SELECT * FROM TBL_BOARD
    </select>

    <!-- 데이터 삽입 -->
    <insert id="insert" parameterType="org.joonzis.domain.BoardVO">
        INSERT INTO TBL_BOARD (bno, title, content, writer, regdate, updatedate)
        VALUES (seq_board.nextval, #{title}, #{content}, #{writer}, SYSDATE, SYSDATE)
   </insert>


    <!-- 단일 조회 -->
    <select id="read" parameterType="int" resultType="org.joonzis.domain.BoardVO">
        SELECT * FROM TBL_BOARD WHERE bno = #{bno}
    </select>

    <!-- 삭제 -->
    <delete id="delete" parameterType="int">
        DELETE FROM TBL_BOARD WHERE bno = #{bno}
    </delete>

    <!-- 수정 -->
    <update id="update" parameterType="org.joonzis.domain.BoardVO">
        UPDATE TBL_BOARD
        SET title = #{title},
            content = #{content},
            writer = #{writer},
            updatedate = SYSDATE
        WHERE bno = #{bno}
    </update>

</mapper>
